# ---------------------------------------------------------------------------
# PulseBoard environment variables
# Copy to .env.local for local dev; set the same keys in Netlify → Site
# configuration → Environment variables for production.
# ---------------------------------------------------------------------------

# --- Frontend (safe to expose; must be prefixed VITE_) ---------------------
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-public-key

# Public base URL of the deployed site (used to build OAuth redirect URIs).
# Local: http://localhost:8888   Production: https://your-site.netlify.app
VITE_SITE_URL=http://localhost:8888

# --- Backend only (NEVER prefixed with VITE_, never sent to the browser) ---
# Supabase service role key — full DB access, used only inside Netlify Functions.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Meta (Facebook + Instagram Graph API) app credentials.
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret

# TikTok for Developers app credentials.
TIKTOK_CLIENT_KEY=your-tiktok-client-key
TIKTOK_CLIENT_SECRET=your-tiktok-client-secret

# Random 32+ char string used to sign OAuth state tokens.
OAUTH_STATE_SECRET=change-me-to-a-long-random-string

# Anthropic API key — powers the AI Assistant (/api/ai). Optional: if unset,
# the Assistant shows a "not configured" message and the rest of the app works.
ANTHROPIC_API_KEY=your-anthropic-api-key
